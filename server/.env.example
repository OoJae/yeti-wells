# Yeti Wells backend env — copy to .env and fill in. NEVER commit the real .env (see .dockerignore/.gitignore).
SUI_NETWORK=testnet

# Secrets (server-side only)
ENOKI_SECRET_KEY=enoki_private_...
FUNDER_SECRET_KEY=suiprivkey1...           # admin/deployer key: owns AdminCap + UpgradeCap, pays gas
STEWARD_KEY=choose-a-long-random-string    # gates /api/steward/* (use 24+ random chars)
SIM_SEED_HEX=                               # 32-byte hex seed for the demo attestation signer (Railway-only secret)

# On-chain ids
PACKAGE_ID=0x...            # ORIGINAL publish (struct/event type tags)
PACKAGE_ID_V2=0x...         # Phase-5 upgrade (AppWitness type origin)
PACKAGE_ID_V3=0x...         # latest upgrade (Move CALL targets)
REGISTRY_ID=0x...
ADMIN_CAP_ID=0x...
ENCLAVE_CAP_ID=0x...        # Cap<AppWitness> (used by register-enclave.ts)
ENCLAVE_ID_SIM=0x...        # secret-seed dev Enclave<AppWitness> new campaigns bind to (sim mode)
ENCLAVE_ID=                 # genuine Oyster/Nitro enclave (leave empty for sim mode)
ENCLAVE_URL=                # genuine enclave URL (leave empty for sim mode)

# Tunables
PORT=3001
ALLOWED_ORIGIN=http://localhost:5173        # set to the exact Vercel origin in production
GRANT_AMOUNT_MIST=100000000                 # 0.1 SUI starter grant
FUND_DAILY_CAP_MIST=3000000000              # 3 SUI/day total grant budget
FUNDER_MIN_BALANCE_MIST=200000000           # circuit-breaker: stop granting below 0.2 SUI
WALRUS_PUBLISHER=https://publisher.walrus-testnet.walrus.space
