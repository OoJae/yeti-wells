// SEC-02 clamp: an under-funded milestone releases only the available escrow instead of aborting.
#[test]
fun test_submit_v2_underfunded_clamp() {
    let mut sc = setup();
    alice_donates(&mut sc, 1_000_000_000); // 1 SUI < milestone 0 nominal release of 3 SUI
    register_dev_enclave(&mut sc);
    bind_enclave(&mut sc);
    ts::next_tx(&mut sc, ADMIN);
    {
        let mut reg = ts::take_shared<Registry>(&sc);
        let mut proj = ts::take_shared<WaterProject>(&sc);
        let enc = ts::take_shared<enclave::Enclave<AppWitness>>(&sc);
        let pid = object::id_address(&proj);
        attestation::submit_attested_milestone_v2(
            &mut proj, &mut reg, &enc, TS_MS, pid, 0, 60_000, SIG_V2_HAPPY, ts::ctx(&mut sc));
        assert!(project::milestone_released(&proj, 0), 0);
        assert!(project::escrow_value(&proj) == 0, 1); // clamped: released all 1 SUI, no abort
        ts::return_shared(enc);
        ts::return_shared(proj);
        ts::return_shared(reg);
    };
    ts::next_tx(&mut sc, PAYOUT);
    {
        let paid = ts::take_from_sender<Coin<SUI>>(&sc);
        assert!(coin::value(&paid) == 1_000_000_000, 2);
        ts::return_to_sender(&sc, paid);
    };
    ts::end(sc);
}

// ECON-02: a later donation that dilutes `raised` must NOT shrink an earlier donor's attributed liters.
#[test]
fun test_attribution_monotonic_after_dilution() {
    let mut sc = setup();
    alice_donates(&mut sc, 6_000_000_000); // raised 6 SUI, Alice donated 6 SUI
    register_dev_enclave(&mut sc);
    bind_enclave(&mut sc);
    ts::next_tx(&mut sc, ADMIN);
    {
        let mut reg = ts::take_shared<Registry>(&sc);
        let mut proj = ts::take_shared<WaterProject>(&sc);
        let enc = ts::take_shared<enclave::Enclave<AppWitness>>(&sc);
        let pid = object::id_address(&proj);
        attestation::submit_attested_milestone_v2(
            &mut proj, &mut reg, &enc, TS_MS, pid, 0, 60_000, SIG_V2_HAPPY, ts::ctx(&mut sc));
        ts::return_shared(enc);
        ts::return_shared(proj);
        ts::return_shared(reg);
    };
    // Alice syncs: 60_000 * 6e9 / 6e9 = 60_000.
    ts::next_tx(&mut sc, ALICE);
    {
        let proj = ts::take_shared<WaterProject>(&sc);
        let mut nft = ts::take_from_sender<ImpactNFT>(&sc);
        impact_nft::sync_impact(&mut nft, &proj);
        assert!(impact_nft::liters_attributed(&nft) == 60_000, 0);
        ts::return_to_sender(&sc, nft);
        ts::return_shared(proj);
    };
    // Bob donates 6 SUI -> raised 12 SUI (dilutes the denominator).
    ts::next_tx(&mut sc, BOB);
    {
        let mut reg = ts::take_shared<Registry>(&sc);
        let mut proj = ts::take_shared<WaterProject>(&sc);
        let c = coin::mint_for_testing<SUI>(6_000_000_000, ts::ctx(&mut sc));
        donation::donate(&mut proj, &mut reg, c, ts::ctx(&mut sc));
        ts::return_shared(proj);
        ts::return_shared(reg);
    };
    // Alice re-syncs: computed would be 30_000, but monotonic clamp keeps 60_000.
    ts::next_tx(&mut sc, ALICE);
    {
        let proj = ts::take_shared<WaterProject>(&sc);
        let mut nft = ts::take_from_sender<ImpactNFT>(&sc);
        impact_nft::sync_impact(&mut nft, &proj);
        assert!(impact_nft::liters_attributed(&nft) == 60_000, 1); // did NOT regress to 30_000
        ts::return_to_sender(&sc, nft);
        ts::return_shared(proj);
    };
    ts::end(sc);
}
