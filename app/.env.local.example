# Yeti Wells frontend env — copy to .env.local. All VITE_ vars are PUBLIC (shipped to the browser).
VITE_SUI_NETWORK=testnet
VITE_ENOKI_PUBLIC_KEY=enoki_public_...
VITE_GOOGLE_CLIENT_ID=...apps.googleusercontent.com
VITE_API_URL=http://localhost:3001          # the backend origin

# Package ids: PACKAGE_ID = original (struct/event TYPE tags); CALL = latest upgrade (Move call targets).
VITE_PACKAGE_ID=0x...
VITE_CALL_PACKAGE_ID=0x...
VITE_REGISTRY_ID=0x...

# Genuine AWS-Nitro enclave id (empty while running the demo sim signer) — drives the "Verified by TEE" badge.
VITE_GENUINE_ENCLAVE_ID=
# Comma-separated campaign ids to hide from Browse (old/test/demo projects).
VITE_PROJECT_DENYLIST=
VITE_WALRUS_AGGREGATOR=https://aggregator.walrus-testnet.walrus.space
